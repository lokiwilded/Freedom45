{
  "name": "freedom45-mcp-server",
  "version": "0.1.0",
  "description": "Trading & investing MCP server",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsc --watch",
    "test:congress": "node --env-file=../.env --import tsx src/test/getCongressTrades.test.ts",
    "test:profile": "node --env-file=../.env --import tsx src/test/long-analysis/fetchCompanyProfile.test.ts",
    "test:profile-tool": "node --env-file=../.env --import tsx src/test/long-analysis/fetchCompanyProfileTool.test.ts",
    "test:quote": "node --env-file=../.env --import tsx src/test/long-analysis/fetchStockQuote.test.ts",
    "test:history": "node --env-file=../.env --import tsx src/test/long-analysis/fetchHistoricalPrices.test.ts",
    "test:fundamentals": "node --env-file=../.env --import tsx src/test/long-analysis/fetchFundamentalMetrics.test.ts",
    "test:peers": "node --env-file=../.env --import tsx src/test/long-analysis/fetchPeers.test.ts",
    "test:trend": "node --env-file=../.env --import tsx src/test/long-analysis/analyzeLongTermTrend.test.ts",
    "test:search": "node --env-file=../.env --import tsx src/test/long-analysis/searchStocks.test.ts",
    "test:insider": "node --env-file=../.env --import tsx src/test/long-analysis/getInsiderTransactions.test.ts",
    "test:company-news": "node --env-file=../.env --import tsx src/test/long-analysis/getCompanyNews.test.ts",
    "test:market-news": "node --env-file=../.env --import tsx src/test/long-analysis/getMarketNews.test.ts",
    "test:earnings-cal": "node --env-file=../.env --import tsx src/test/long-analysis/getEarningsCalendar.test.ts",
    "test:earnings": "node --env-file=../.env --import tsx src/test/long-analysis/getEarningsSurprise.test.ts",
    "test:recommendations": "node --env-file=../.env --import tsx src/test/long-analysis/getRecommendationTrends.test.ts",
    "test:price-target": "node --env-file=../.env --import tsx src/test/long-analysis/getPriceTarget.test.ts",
    "test:updown": "node --env-file=../.env --import tsx src/test/long-analysis/getUpgradeDowngrade.test.ts",
    "test:dividends": "node --env-file=../.env --import tsx src/test/long-analysis/getDividends.test.ts",
    "test:splits": "node --env-file=../.env --import tsx src/test/long-analysis/getSplits.test.ts",
    "test:sec": "node --env-file=../.env --import tsx src/test/long-analysis/getSecFilings.test.ts",
    "test:inst-own": "node --env-file=../.env --import tsx src/test/long-analysis/getInstitutionalOwnership.test.ts",
    "test:fund-own": "node --env-file=../.env --import tsx src/test/long-analysis/getFundOwnership.test.ts",
    "test:valuation": "node --env-file=../.env --import tsx src/test/long-analysis/analyzeValuation.test.ts",
    "test:relative-strength": "node --env-file=../.env --import tsx src/test/long-analysis/analyzeRelativeStrength.test.ts",
    "test:calcs": "node --import tsx src/test/shared/calculations.test.ts",
    "test:registry": "node --env-file=../.env --import tsx src/test/shared/registry.test.ts",
    "test:cache": "node --env-file=../.env --import tsx src/test/shared/cacheOnly.test.ts",
    "test:all": "npm run test:profile && npm run test:profile-tool && npm run test:quote && npm run test:history && npm run test:fundamentals && npm run test:peers && npm run test:trend && npm run test:search && npm run test:insider && npm run test:company-news && npm run test:market-news && npm run test:earnings-cal && npm run test:earnings && npm run test:recommendations && npm run test:price-target && npm run test:updown && npm run test:dividends && npm run test:splits && npm run test:sec && npm run test:inst-own && npm run test:fund-own && npm run test:valuation && npm run test:relative-strength && npm run test:registry && npm run test:cache && npm run test:calcs",
    "test:offline": "npm run test:registry && npm run test:cache && npm run test:calcs"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.5.0"
  }
}